
<!doctype html>
{% set pageLang = lang or '' %}
{% if not pageLang and page.url and (page.url | slice(0,4)) == '/de/' %}{% set pageLang = 'de' %}{% endif %}
{% if not pageLang and page.url and (page.url | slice(0,4)) == '/en/' %}{% set pageLang = 'en' %}{% endif %}
{% if not pageLang and page.url and (page.url | slice(0,4)) == '/fr/' %}{% set pageLang = 'fr' %}{% endif %}
{% if not pageLang and page.url and (page.url | slice(0,4)) == '/pt/' %}{% set pageLang = 'pt' %}{% endif %}
{% if not pageLang %}{% set pageLang = 'en' %}{% endif %}
<html lang="{{ pageLang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% set canonicalUrl = site.canonicalBase ~ (page.url or '/') %}
  {% set xDefaultUrl = site.canonicalBase ~ '/en/' %}
  {% set ogLocale = {'de':'de_DE','en':'en_US','fr':'fr_FR','pt':'pt_PT'}[pageLang] or 'en_US' %}
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  {% set route = page.url or '/' %}
  {% set metaKeywords = keywords %}
  {% if not metaKeywords %}
    {% if pageLang == 'de' %}
      {% if '/services/' in route %}{% set metaKeywords = 'Services Luxus Madeira, Luxusreinigung Madeira, Premium Reinigung Madeira, Property Care Madeira, private Residenzen Madeira' %}
      {% elif '/landing/' in route or '/al/' in route %}{% set metaKeywords = 'Alojamento Local Madeira, Reinigung Ferienimmobilie Madeira, AL Reinigung Madeira, Premium Cleaning Madeira, Check-in Reinigung Madeira' %}
      {% elif '/check/' in route %}{% set metaKeywords = 'Storm Check Madeira, Unwetterkontrolle Madeira, Objektkontrolle Madeira, Property Care Madeira, Luxusimmobilie Madeira' %}
      {% elif '/orte/' in route %}{% set metaKeywords = 'Luxury Property Care Madeira, Property Care Madeira, Luxusimmobilie Madeira, Villa Betreuung Madeira, Zweitwohnsitz Madeira' %}
      {% else %}{% set metaKeywords = 'Luxury Property Care Madeira, Property Care Madeira, Luxusimmobilie Madeira, Villa Betreuung Madeira, Property Care Madeira' %}
      {% endif %}
    {% elif pageLang == 'fr' %}
      {% if '/services/' in route %}{% set metaKeywords = 'services luxe Madère, nettoyage luxe Madère, nettoyage premium Madère, Property Care Madère, résidences privées Madère' %}
      {% elif '/landing/' in route or '/al/' in route %}{% set metaKeywords = 'Alojamento Local Madère, nettoyage location Madère, nettoyage AL Madère, premium cleaning Madère, préparation arrivée Madère' %}
      {% elif '/check/' in route %}{% set metaKeywords = 'storm check Madère, contrôle tempête Madère, contrôle propriété Madère, Property Care Madère, villa luxe Madère' %}
      {% elif '/lieux/' in route %}{% set metaKeywords = 'luxury Property Care Madère, Property Care Madère, propriété luxe Madère, entretien villa Madère, résidence secondaire Madère' %}
      {% else %}{% set metaKeywords = 'luxury Property Care Madère, Property Care Madère, propriété luxe Madère, entretien villa Madère, property care Madère' %}
      {% endif %}
    {% elif pageLang == 'pt' %}
      {% if '/services/' in route %}{% set metaKeywords = 'serviços luxo Madeira, limpeza luxo Madeira, limpeza premium Madeira, Property Care Madeira, residências privadas Madeira' %}
      {% elif '/landing/' in route or '/al/' in route %}{% set metaKeywords = 'Alojamento Local Madeira, limpeza alojamento Madeira, limpeza AL Madeira, premium cleaning Madeira, preparação de chegada Madeira' %}
      {% elif '/check/' in route %}{% set metaKeywords = 'storm check Madeira, verificação tempestade Madeira, controlo imóvel Madeira, Property Care Madeira, villa luxo Madeira' %}
      {% elif '/locais/' in route %}{% set metaKeywords = 'luxury Property Care Madeira, Property Care Madeira, imóvel de luxo Madeira, manutenção villa Madeira, segunda residência Madeira' %}
      {% else %}{% set metaKeywords = 'luxury Property Care Madeira, Property Care Madeira, imóvel de luxo Madeira, manutenção villa Madeira, property care Madeira' %}
      {% endif %}
    {% else %}
      {% if '/services/' in route %}{% set metaKeywords = 'luxury services Madeira, luxury cleaning Madeira, premium cleaning Madeira, Property Care Madeira, private residences Madeira' %}
      {% elif '/landing/' in route or '/al/' in route %}{% set metaKeywords = 'Alojamento Local Madeira, holiday rental cleaning Madeira, AL cleaning Madeira, premium cleaning Madeira, arrival preparation Madeira' %}
      {% elif '/check/' in route %}{% set metaKeywords = 'storm check Madeira, property inspection Madeira, Property Care Madeira, luxury property Madeira, villa care Madeira' %}
      {% elif '/locations/' in route %}{% set metaKeywords = 'luxury Property Care Madeira, Property Care Madeira, luxury property Madeira, villa care Madeira, second home Madeira' %}
      {% else %}{% set metaKeywords = 'luxury Property Care Madeira, Property Care Madeira, luxury property Madeira, villa care Madeira, property care Madeira' %}
      {% endif %}
    {% endif %}
  {% endif %}
  <meta name="keywords" content="Keyholding, {{ metaKeywords }}">
  <link rel="canonical" href="{{ canonicalUrl }}">
  <link rel="alternate" hreflang="en" href="{{ site.canonicalBase }}{{ langLinks.en }}">
  <link rel="alternate" hreflang="de" href="{{ site.canonicalBase }}{{ langLinks.de }}">
  <link rel="alternate" hreflang="fr" href="{{ site.canonicalBase }}{{ langLinks.fr }}">
  <link rel="alternate" hreflang="pt" href="{{ site.canonicalBase }}{{ langLinks.pt }}">
  <link rel="alternate" hreflang="x-default" href="{{ xDefaultUrl }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="{{ ogLocale }}">
  <meta property="og:site_name" content="Anjo Property Care Madeira">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:url" content="{{ canonicalUrl }}">
  <meta property="og:image" content="{{ site.canonicalBase }}{{ ogImage or site.ogImage }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="{{ site.canonicalBase }}{{ ogImage or site.ogImage }}">
  <meta name="twitter:url" content="{{ canonicalUrl }}">
  {% set pageType = 'WebPage' %}
  {% if '/faq/' in route %}{% set pageType = 'FAQPage' %}{% elif '/contact/' in route %}{% set pageType = 'ContactPage' %}{% elif '/services/' in route or '/home/' in route or '/check/' in route or '/landing/' in route %}{% set pageType = 'Service' %}{% endif %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "{{ site.canonicalBase }}/#organization",
        "name": "Anjo Property Care Madeira",
        "url": "{{ site.canonicalBase }}/en/",
        "logo": "{{ site.canonicalBase }}/assets/images/logo.svg",
        "email": "{{ site.email }}",
        "sameAs": [{% for profile in site.sameAs %}"{{ profile }}"{% if not loop.last %}, {% endif %}{% endfor %}]
      },
      {
        "@type": "WebSite",
        "@id": "{{ site.canonicalBase }}/#website",
        "url": "{{ site.canonicalBase }}/en/",
        "name": "Anjo Property Care Madeira",
        "publisher": {"@id": "{{ site.canonicalBase }}/#organization"},
        "inLanguage": ["en","de","fr","pt"]
      },
      {
        "@type": "{{ pageType }}",
        "@id": "{{ canonicalUrl }}#webpage",
        "url": "{{ canonicalUrl }}",
        "name": {{ title | dump | safe }},
        "description": {{ description | dump | safe }},
        "isPartOf": {"@id": "{{ site.canonicalBase }}/#website"},
        "about": {"@id": "{{ site.canonicalBase }}/#organization"},
        "inLanguage": "{{ pageLang }}"
      }
    ]
  }
  </script>
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#001f3f">
  <link rel="stylesheet" href="/assets/css/base.css">
  <link rel="stylesheet" href="/assets/css/components.css">
  <link rel="stylesheet" href="/assets/css/cta-icons.css">
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="stylesheet" href="/assets/css/theme.css">

  <!-- SMARTPHONE BACKGROUND FIX -->
  <style>
    html, body{
      min-height: 100% !important;
      background: #000 !important;
    }

    body.l-page{
      position: relative;
      background: transparent !important;
    }

    body.l-page::before{
      content: "";
      position: fixed;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      background-color: #000;
      background-image: url("/assets/images/background.webp");
      background-position: center;
      background-size: cover;
      background-repeat: no-repeat;
      transform: translateZ(0);
      will-change: transform;
    }

    @media (max-width: 820px){
      body.l-page::before{
        background-image: url("/assets/images/backgroundm.webp");
      }
    }
  </style>


  <!-- Google Tag Manager (Consent Mode default denied) -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
      'ad_storage': 'denied',
      'analytics_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'wait_for_update': 500
    });
    gtag('set', 'ads_data_redaction', true);

    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-5BLRDDSL');
  </script>

</head>
<body class="l-page">
  <!-- Google Tag Manager (noscript) -->
  <noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5BLRDDSL"
    height="0" width="0" style="display:none;visibility:hidden"></iframe>
  </noscript>
  {% include "components/header.njk" %}
  <main class="l-main page-wrapper prose-page">
    {{ content | safe }}
  </main>
  {% include "components/back.njk" %}
  {% include "components/footer.njk" %}
  {% include "components/cookie.njk" %}

  {% set showCta = false %}
  {% if page.url %}
    {% set isMainIndex = page.url == ("/" + pageLang + "/") %}
    {% set isContact = page.url.indexOf("/" + pageLang + "/contact/") == 0 %}
    {% set localizedAlRoot = {"de":"/de/landing/al-madeira/","en":"/en/landing/cleaning-for-al/","fr":"/fr/landing/nettoyage-al/","pt":"/pt/landing/limpeza-al/"} %}
    {% set isAl = page.url.indexOf("/" + pageLang + "/al/") == 0 or page.url == localizedAlRoot[pageLang] %}
    {% set isCheck = page.url.indexOf("/" + pageLang + "/check/") == 0 %}
    {% set localizedAreaRoots = {"de":"/de/orte/","en":"/en/locations/","fr":"/fr/lieux/","pt":"/pt/locais/"} %}
    {% set isAreas = page.url.indexOf(localizedAreaRoots[pageLang]) == 0 %}
    {% if isMainIndex or isContact or isAl or isCheck or isAreas %}{% set showCta = true %}{% endif %}
  {% endif %}
  {% if showCta %}
    {% include "components/cta.njk" %}
  {% endif %}
  <script src="/assets/js/nav.js"></script>
  <script src="/assets/js/langfix.js"></script>
  <script src="/assets/js/back.js"></script>
  <script src="/assets/js/cookie.js"></script>
</body>
</html>
