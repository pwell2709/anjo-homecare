{% set t = {
  de: { label: "Zurück" },
  en: { label: "Back" },
  fr: { label: "Retour" },
  pt: { label: "Voltar" }
} %}
{% set L = t[pageLang] or t.de %}

<nav class="back-wrap" role="navigation" aria-label="{{ L.label }} navigation">
  <button
    class="back-btn"
    type="button"
    data-back-button
    data-fallback="/{{ pageLang }}/"
  >
    ← {{ L.label }}
  </button>
</nav>