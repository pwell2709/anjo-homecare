RewriteEngine On

# ----------------------------------------------------
# 1) Language parameter redirects on root
# ----------------------------------------------------
RewriteCond %{QUERY_STRING} (^|&)lang=de(&|$) [NC]
RewriteRule ^$ /de/? [R=301,L]

RewriteCond %{QUERY_STRING} (^|&)lang=en(&|$) [NC]
RewriteRule ^$ /en/? [R=301,L]

RewriteCond %{QUERY_STRING} (^|&)lang=fr(&|$) [NC]
RewriteRule ^$ /fr/? [R=301,L]

RewriteCond %{QUERY_STRING} (^|&)lang=pt(&|$) [NC]
RewriteRule ^$ /pt/? [R=301,L]

# ----------------------------------------------------
# 2) Remove legacy lang parameter on non-root URLs
# ----------------------------------------------------
RewriteCond %{QUERY_STRING} (^|&)lang=(de|en|fr|pt)(&|$) [NC]
RewriteCond %{REQUEST_URI} !^/$
RewriteRule ^ %{REQUEST_URI}? [R=301,L]

# ----------------------------------------------------
# 3) www -> non-www
# ----------------------------------------------------
RewriteCond %{HTTP_HOST} ^www\.anjo-cleaning\.com$ [NC]
RewriteRule ^ https://anjo-cleaning.com%{REQUEST_URI} [R=301,L]

# ----------------------------------------------------
# 4) Force HTTPS (Strato safe)
# ----------------------------------------------------
RewriteCond %{HTTP:X-Forwarded-Proto} =http [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

RewriteCond %{HTTP:X-Forwarded-Proto} =""
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ----------------------------------------------------
# 5) Root redirect
# ----------------------------------------------------
RewriteRule ^index\.html$ /en/ [R=301,L]
RewriteRule ^$ /en/ [R=301,L]

# ----------------------------------------------------
# 6) Language root cleanup
# ----------------------------------------------------
RewriteRule ^(de|en|fr|pt)$ /$1/ [R=301,L]

# ----------------------------------------------------
# 7) Remove index.html inside languages
# ----------------------------------------------------
RewriteRule ^(de|en|fr|pt)/index\.html$ /$1/ [R=301,L,NC]

# ----------------------------------------------------
# 8) Remove .html for all real language pages
# ----------------------------------------------------
RewriteRule ^(de|en|fr|pt)/(.*)\.html$ /$1/$2/ [R=301,L,NC]

# ----------------------------------------------------
# 9) Legacy redirects (old site)
# ----------------------------------------------------

Redirect 301 /de/cleaning/ https://anjo-cleaning.com/de/services/
Redirect 301 /de/reinigung/ https://anjo-cleaning.com/de/services/

Redirect 301 /en/cleaning/ https://anjo-cleaning.com/en/services/
Redirect 301 /fr/nettoyage/ https://anjo-cleaning.com/fr/services/
Redirect 301 /pt/limpeza/ https://anjo-cleaning.com/pt/services/

Redirect 301 /de/house/ https://anjo-cleaning.com/de/home/
Redirect 301 /en/house/ https://anjo-cleaning.com/en/home/
Redirect 301 /fr/house/ https://anjo-cleaning.com/fr/home/
Redirect 301 /pt/house/ https://anjo-cleaning.com/pt/home/

Redirect 301 /de/home-care-service-madeira/ https://anjo-cleaning.com/de/home/
Redirect 301 /en/home-care-service-madeira/ https://anjo-cleaning.com/en/home/
Redirect 301 /fr/home-care-service-madeira/ https://anjo-cleaning.com/fr/home/
Redirect 301 /pt/home-care-service-madeira/ https://anjo-cleaning.com/pt/home/

Redirect 301 /de/house-sitting-madeira/ https://anjo-cleaning.com/de/home/
Redirect 301 /en/house-sitting-madeira/ https://anjo-cleaning.com/en/home/
Redirect 301 /fr/house-sitting-madeira/ https://anjo-cleaning.com/fr/home/
Redirect 301 /pt/house-sitting-madeira/ https://anjo-cleaning.com/pt/home/

Redirect 301 /de/Home%20Care%20Service-madeira/ https://anjo-cleaning.com/de/home/
Redirect 301 /en/Home%20Care%20Service-madeira/ https://anjo-cleaning.com/en/home/
Redirect 301 /fr/Home%20Care%20Service-madeira/ https://anjo-cleaning.com/fr/home/
Redirect 301 /pt/Home%20Care%20Service-madeira/ https://anjo-cleaning.com/pt/home/

Redirect 301 /de/landing/al-madeira/ https://anjo-cleaning.com/de/landing/alto/
Redirect 301 /en/landing/cleaning-for-al/ https://anjo-cleaning.com/en/landing/alto/
Redirect 301 /fr/landing/nettoyage-al/ https://anjo-cleaning.com/fr/landing/alto/
Redirect 301 /pt/landing/limpeza-al/ https://anjo-cleaning.com/pt/landing/alto/

# ----------------------------------------------------
# Security
# ----------------------------------------------------
Options -Indexes

# ----------------------------------------------------
# Charset
# ----------------------------------------------------
AddDefaultCharset UTF-8
AddCharset UTF-8 .html .css .js .json .xml .svg

# ----------------------------------------------------
# Custom 404
# ----------------------------------------------------
ErrorDocument 404 /404.html