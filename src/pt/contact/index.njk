</style>


  <div class="hero-logo hero-logo--small">
    <img src="/assets/images/logo.svg" alt="Anjo Cleaning Logo" width="720" height="220" loading="eager" decoding="async">
  </div>
<div class="contact-premium" data-contact-lock="live">
  <div class="topRow">
    <h1 id="title">Contacto</h1>
  </div>

  <p class="subline" id="intro">
    Envie-nos uma mensagem para disponibilidade, preços ou um plano de limpeza à medida. Respondemos o mais rápido possível.
  </p>

  <div class="card">
    <form action="/send.php" id="contactForm" method="post" novalidate="">
      <!-- Honeypot -->
      <div aria-hidden="true" style="position:absolute; left:-10000px; top:auto; width:1px; height:1px; overflow:hidden;">
        <label for="website">Website</label>
        <input id="website" name="website" type="text" tabindex="-1" autocomplete="off"/>
      </div>

      <input type="hidden" name="lang" value="pt"/>
      <input type="hidden" name="page" value="/pt/contact/"/>

      <div class="grid two">
        <div>
          <label for="name">Nome <span class="req">*</span></label>
          <input class="field" id="name" name="name" type="text" autocomplete="name" placeholder="O seu nome" required=""/>
        </div>

        <div>
          <label for="email">E-mail <span class="req">*</span></label>
          <input class="field" id="email" name="email" type="email" autocomplete="email" placeholder="info@anjo-cleaning.com" required=""/>
        </div>
      </div>

      <div class="grid two" style="margin-top:12px;">
        <div>
          <label for="phone">Telefone (opcional)</label>
          <input class="field" id="phone" name="phone" type="tel" autocomplete="tel" placeholder="+351 …"/>
        </div>

        <div>
          <label for="serviceSelectBtn">Serviço <span class="req">*</span></label>

          <input type="hidden" id="service" name="service" value="" required=""/>

          <div class="select" data-select>
            <button
              type="button"
              class="selectBtn"
              id="serviceSelectBtn"
              aria-haspopup="listbox"
              aria-expanded="false"
            >
              <span class="value"><span class="placeholder">Selecionar…</span></span>
              <svg class="chev" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M7 10l5 5 5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <div class="listbox" role="listbox" aria-label="Selecionar serviço">
              <button type="button" class="option option--spacer" aria-hidden="true" tabindex="-1"></button>
              <button type="button" class="option" role="option" data-value="house_sitting" aria-selected="false">Property Care de Luxo</button>
              <button type="button" class="option" role="option" data-value="services_luxury" aria-selected="false">Serviços de Luxo</button>
              <button type="button" class="option" role="option" data-value="storm_check" aria-selected="false">Controlo de tempestade (exterior)</button>
              <button type="button" class="option" role="option" data-value="holiday_al" aria-selected="false">AL Alojamento Local</button>
              <button type="button" class="option" role="option" data-value="other" aria-selected="false">Outros</button>
            </div>
          </div>
        </div>
      </div>

      <div style="margin-top:12px;">
        <label for="message">Mensagem <span class="req">*</span></label>
        <textarea class="field" id="message" name="message" placeholder="Em que podemos ajudar? (local, tamanho, datas, pedidos especiais)…" required=""></textarea>
      </div>

      <div class="checkwrap">
        <input id="consent" name="consent" type="checkbox" required=""/>
        <div class="fineprint">
          Li e tomei conhecimento da <a class="mutedLink" href="/pt/privacy/">Política de Privacidade</a>. <span class="req">*</span>
        </div>
      </div>

      <div class="fineprint" id="retentionText">
        <b>Conservação:</b> pedidos sem contrato até 12 meses; documentos contratuais/contabilísticos geralmente 10 anos (Portugal).
      </div>

      <div class="fineprint" id="processingText">
        <b>Tratamento:</b> tratamos os seus dados para responder ao seu pedido e para medidas pré-contratuais (Art. 6(1)(b) RGPD).
        <b>Destinatários:</b> não partilhamos com terceiros; envio por e-mail do servidor.
        <b>Direitos:</b> acesso/apagamento/oposição, etc. ver a <a class="mutedLink" href="/pt/privacy/">Política de Privacidade</a>.
      </div>

      <div class="actions">
        <button class="btnPremium" id="btnSend" type="submit">Enviar</button>
        <div class="hintline" id="hint">Resposta geralmente em 24 h (dias úteis).</div>
      </div>

      <div class="status err" id="errBox" role="status" aria-live="polite"></div>
      <div class="status ok" id="okBox" role="status" aria-live="polite"></div>
    </form>
  </div>

<script>
(function(){
  const form = document.getElementById("contactForm");
  const err = document.getElementById("errBox");
  const ok  = document.getElementById("okBox");
  const btn = document.getElementById("btnSend");

  const hiddenService = document.getElementById("service");
  const selectWrap = document.querySelector("[data-select]");
  const selectBtn = document.getElementById("serviceSelectBtn");
  const listbox = selectWrap ? selectWrap.querySelector(".listbox") : null;
  const valueEl = selectWrap ? selectWrap.querySelector(".value") : null;
  const options = listbox ? Array.from(listbox.querySelectorAll(".option[data-value]")) : [];



  // Restrict service options when coming from Property Care / Locations pages
  try{
    const qs = new URLSearchParams(window.location.search);
    const src = qs.get("src") || sessionStorage.getItem("src");
    if(src === "orte"){
      const allowed = new Set(["storm_check","house_sitting"]);
      options.forEach(opt=>{
        const v = opt.getAttribute("data-value");
        if(!allowed.has(v)){
          opt.style.display = "none";
        }
      });
      // If a hidden option was preselected, reset selection
      if(hiddenService && hiddenService.value && !allowed.has(hiddenService.value)){
        hiddenService.value = "";
        if(valueEl) valueEl.textContent = "";
      }
      // Clear the marker after applying
      if(!qs.get("src")){ sessionStorage.removeItem("src"); }
    }
  }catch(e){}

  if(!form || !err || !ok || !btn) return;

  function escapeHtml(s){
    return String(s).replace(/[&<>"']/g, (c)=>({ "&":"&amp;", "<":"&lt;", ">":"&gt;", '"':"&quot;", "'":"&#39;" }[c]));
  }

  function setBusy(isBusy){
    btn.disabled = isBusy;
    btn.setAttribute("aria-busy", isBusy ? "true" : "false");
    if(isBusy){
      btn.dataset.label = btn.textContent;
      btn.textContent = "A enviar…";
    }else{
      btn.textContent = btn.dataset.label || "Enviar";
    }
  }

  function showErr(msg){
    err.innerHTML = "<b>Erro:</b> " + escapeHtml(msg);
    err.style.display = "block";
    ok.style.display = "none";
  }

  function showOk(msg){
    ok.innerHTML = "<b>Enviado:</b> " + escapeHtml(msg);
    ok.style.display = "block";
    err.style.display = "none";
  }

  function val(id){
    return (document.getElementById(id)?.value || "").trim();
  }

  function openList(){
    if(!listbox) return;
    listbox.classList.add("open");
    selectBtn.setAttribute("aria-expanded", "true");
  }

  function closeList(){
    if(!listbox) return;
    listbox.classList.remove("open");
    selectBtn.setAttribute("aria-expanded", "false");
  }

  function setSelected(value, label){
    if(hiddenService){
      hiddenService.value = value || "";
      hiddenService.setAttribute("value", value || "");
    }
    if(valueEl){
      valueEl.innerHTML = label ? escapeHtml(label) : '<span class="placeholder">Selecionar…</span>';
    }
    options.forEach(o=>{
      o.setAttribute("aria-selected", o.dataset.value === value ? "true" : "false");
    });
  }


  // Optional: restrict service options when coming from most location pages
  const params = new URLSearchParams(window.location.search || "");
  const from = (params.get("from") || "").trim();
  const serviceParam = (params.get("service") || "").trim();
  const locationExceptions = ["ponta-do-sol","calheta","ribeira-brava"];

  if(from && !locationExceptions.includes(from)){
    options.forEach(o=>{
      const v = (o.dataset.value || "");
      if(v !== "house_sitting" && v !== "storm_check"){
        o.style.display = "none";
      }else{
        o.style.display = "";
      }
    });
  }

  // Optional: preselect service from URL (?service=house_sitting | storm_check)
  if(serviceParam && options.length){
    const opt = options.find(o => (o.dataset.value || "") === serviceParam);
    if(opt){
      setSelected(serviceParam, opt.textContent || "");
    }
  }

  if(selectBtn && listbox){
    selectBtn.addEventListener("click", ()=>{
      if(listbox.classList.contains("open")) closeList();
      else openList();
    });

    options.forEach(o=>{
      o.addEventListener("click", ()=>{
        setSelected(o.dataset.value || "", o.textContent || "");
        closeList();
      });
    });

    document.addEventListener("click", (e)=>{
      if(!selectWrap) return;
      if(selectWrap.contains(e.target)) return;
      closeList();
    });

    document.addEventListener("keydown", (e)=>{
      if(e.key === "Escape") closeList();
    });
  }

  form.addEventListener("submit", async (e)=>{
    e.preventDefault();

    const name = val("name");
    const email = val("email");
    const service = hiddenService ? (hiddenService.value || "") : "";
    const message = val("message");
    const consent = !!document.getElementById("consent")?.checked;

    if(!name || !email || !service || !message){
      return showErr("Por favor, preencha todos os campos obrigatórios (*).");
    }
    if(!consent){
      return showErr("Por favor, confirme a Política de Privacidade (checkbox).");
    }

    setBusy(true);

    try{
      const fd = new FormData(form);
      fd.set("lang", "pt");

      const res = await fetch(form.action, { method: "POST", body: fd });
      const text = await res.text();

      if(res.status === 429){
        let retry = 0;
        try{
          const data429 = JSON.parse(text);
          retry = parseInt(data429.retry_after || 0, 10);
        }catch(_e){}
        if(retry > 0) throw new Error(("Demasiados pedidos. Aguarde {s} segundos.").replace("{s}", String(retry)));
        throw new Error("Demasiados pedidos. Aguarde um momento e tente novamente.");
      }

      let data = null;
      try{ data = JSON.parse(text); }catch(_e){ data = null; }

      if(data){
        if(data.error) throw new Error(data.error);
        if(!(res.ok && data.ok !== false)) throw new Error(data.message || "Erro do servidor");
      }else{
        if(!res.ok) throw new Error("Erro do servidor");
      }

      showOk("Obrigado. O seu pedido foi enviado.");
      form.reset();
      setSelected("", "");
      closeList();
    }catch(ex){
      showErr("Envio falhou: " + (ex && ex.message ? ex.message : "Erro desconhecido"));
    }finally{
      setBusy(false);
    }
  });
})();
</script>


