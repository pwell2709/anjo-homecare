  font-size: .95rem;
  opacity: .85;
}

.contact-premium .status{
  margin-top: 12px;
  border-radius: 16px;
  padding: 12px 14px;
  display: none;
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.10);
}

.contact-premium .status.ok{
