<style>
/* Premium Contact – scoped */
/* CONTACT_LOCK: keep contact form identical to live. */
.contact-premium{
  max-width: 980px;
  margin: 0 auto;
  padding: 6px 0 18px;
}

.contact-premium .subline{
  max-width: 760px;
  margin: 8px 0 18px;
  opacity: .9;
}

.contact-premium[data-contact-lock="live"] .card{
  background: rgba(255,255,255,.08);
  border-radius: 18px;
  padding: 18px;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  box-shadow: 0 10px 30px rgba(0,0,0,.08);
}

.contact-premium .grid{
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
}

@media (min-width: 760px){
  .contact-premium .grid.two{
    grid-template-columns: 1fr 1fr;
    gap: 14px 18px;
  }
}

.contact-premium label{
  display: block;
  font-weight: 700;
  margin: 0 0 8px;
}

.contact-premium .req{
  opacity: .7;
  font-weight: 700;
}

.contact-premium[data-contact-lock="live"] .field{
  width: 100%;
  border: 0;
  outline: none;
  border-radius: 16px;
  padding: 14px 14px;
  background: rgba(0,0,0,.14);
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.08);
  color: inherit;
  transition: box-shadow .18s ease, background .18s ease;
}

.contact-premium .field::placeholder{
  opacity: .7;
}

.contact-premium .field:focus{
  background: rgba(0,0,0,.10);
  box-shadow:
    inset 0 0 0 1px rgba(255,255,255,.14),
    0 0 0 4px rgba(0,31,63,.18);
}

.contact-premium textarea.field{
  min-height: 170px;
  resize: vertical;
  line-height: 1.35;
}

/* Custom dropdown */
.contact-premium .select{
  position: relative;
}

.contact-premium .selectBtn{
  width: 100%;
  text-align: left;
  border: 0;
  outline: none;
  border-radius: 16px;
  padding: 14px 44px 14px 14px;
  background: rgba(0,0,0,.14);
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.08);
  color: inherit;
  cursor: pointer;
  transition: box-shadow .18s ease, background .18s ease;
}

.contact-premium .selectBtn:focus{
  background: rgba(0,0,0,.10);
  box-shadow:
    inset 0 0 0 1px rgba(255,255,255,.14),
    0 0 0 4px rgba(0,31,63,.18);
}

.contact-premium .selectBtn .placeholder{
  opacity: .7;
}

.contact-premium .chev{
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  width: 18px;
  height: 18px;
  opacity: .9;
  pointer-events: none;
}

.contact-premium .listbox{
  position: absolute;
  left: 0;
  right: 0;
  top: calc(100% + 8px);
  z-index: 20;
  display: none;
  border-radius: 16px;
  background: rgba(0,0,0,.14);
  box-shadow:
    inset 0 0 0 1px rgba(255,255,255,.08),
    0 14px 34px rgba(0,0,0,.18);
  overflow: hidden;
}

.contact-premium .listbox.open{
  display: block;
}

.contact-premium .option{
  width: 100%;
  border: 0;
  background: transparent;
  color: inherit;
  text-align: left;
  padding: 12px 14px;
  cursor: pointer;
  transition: background .14s ease;
}

.option--spacer{
  pointer-events:none;
  cursor: default;
  opacity: 0;
}

.contact-premium .contact-premium .option:hover,
.contact-premium .option[aria-selected="true"]{
  background: rgba(0,0,0,.10);
}

.contact-premium .checkwrap{
  margin-top: 12px;
  background: rgba(0,0,0,.14);
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.08);
  border-radius: 16px;
  padding: 14px 14px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.contact-premium input[type="checkbox"]{
  width: 18px;
  height: 18px;
  margin-top: 2px;
  accent-color: #001f3f;
  flex: 0 0 auto;
}

.contact-premium .fineprint{
  margin-top: 12px;
  font-size: .95rem;
  opacity: .92;
}

.contact-premium .mutedLink{
  color: inherit;
  opacity: .95;
  text-decoration: underline;
  text-underline-offset: 3px;
}

.contact-premium .actions{
  margin-top: 14px;
  display: flex;
  gap: 10px;
  align-items: center;
}

.contact-premium .btnPremium{
  background: none;
  border: none;
  padding: 0;
  font-weight: 800;
  font-size: 1rem;
  color: #001f3f;
